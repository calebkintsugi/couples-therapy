# OpenAI API Key - Required for generating personalized advice
OPENAI_API_KEY=your_openai_api_key_here

# Server port (optional, defaults to 3001)
PORT=3001

# Email notifications (optional - for analytics access alerts)
# For Gmail, use an App Password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Encryption key for securing sensitive data at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Store this securely and never lose it - data encrypted with this key cannot be recovered without it
ENCRYPTION_KEY=your_32_byte_hex_key_here
